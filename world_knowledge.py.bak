def get_business_intelligence(code: str, name: str) -> dict:
    """获取企业世界知识"""
    if code in BUSINESS_WORLD_KNOWLEDGE:
        return BUSINESS_WORLD_KNOWLEDGE[code]
    for key, val in BUSINESS_WORLD_KNOWLEDGE.items():
        if val.get("name") == name:
            return val
