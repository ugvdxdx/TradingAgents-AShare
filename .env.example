# --- 核心模型接入 (Core LLM) ---
TA_API_KEY=
TA_BASE_URL=https://api.openai.com/v1
TA_LLM_PROVIDER=openai

# 模型名配置 (默认已提供常用值)
TA_LLM_QUICK=gpt-4o-mini
TA_LLM_DEEP=gpt-4o

# --- 进阶可选配置 (Advanced Optional) ---
# 提示词语言 (auto / zh / en)，默认 zh
# TA_LANGUAGE=zh

# 运行日志追踪 (1 开启 / 0 关离)，默认 1
# TA_TRACE=1

# 辩论与风险讨论轮数 (1-5)，默认 1
# TA_MAX_DEBATE=1
# TA_MAX_RISK=1

# --- VLM 截图识别 (Vision Language Model) ---
# 用于持仓截图识别，默认使用智谱 glm-4.6v-flash（免费）
# TA_VLM_API_KEY=你的智谱API Key
# TA_VLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# TA_VLM_MODEL=glm-4.6v-flash

# --- 企业微信通知 (WeCom) ---
# 定时分析完成后自动推送报告
# TA_WECOM_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=YOUR_KEY
# TA_WECOM_REPORT_ENABLED=1

# --- 邮件通知 (Email) ---
# 定时分析完成后自动推送邮件报告
# TA_EMAIL_REPORT_TO=your@email.com

# --- 数据源配置 ---
# 数据源供应商优先级，默认 cn_astock 为首选
# TA_DATA_VENDORS_CORE=cn_astock,cn_akshare,cn_baostock,yfinance

# --- 选股流水线数据源 (Tushare / StockAPI) ---
# Tushare: 真实财报(fundamentals_data.py) + 资金流(money_flow.py fallback)
#   申请: https://tushare.pro/register
TUSHARE_TOKEN=

# StockAPI: 行业分类数据 (fundamental_agent.py 历史)
#   申请: https://www.stockapi.com.cn/
STOCKAPI_TOKEN=

# --- 研报知识系统 (小鹅通圈子) ---
# 财经博主圈子登录 Cookie, 用于采集研报数据 (research.db)
# 获取方式: 浏览器登录 quanzi.xiaoe-tech.com 后, 从开发者工具复制完整 Cookie
# 过期后需重新获取; run_research_pipeline.py / run_daily_update.py 会检测过期并以非零码退出
XIAOE_COOKIE=